# ══════════════════════════════════════════════════════════════
# Paper Flow AI — GitHub Codespaces Deployment
# ══════════════════════════════════════════════════════════════
# Usage: cp .env.codespaces .env  (then fill in your API keys)
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=securepassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=research_assistant
DATABASE_URL=postgresql+asyncpg://admin:securepassword@postgres:5432/research_assistant

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ══════════════════════════════════════════════════════════════
# LLM — 5 Groq API keys, one per service
# ══════════════════════════════════════════════════════════════
LLM_PROVIDER=groq

# Key 1 → Chatbot
GROQ_API_KEY=gsk_PASTE_KEY_1_HERE
CHAT_LLM_PROVIDER=groq

# Key 2 → Summarization
GROQ_API_KEY_2=gsk_PASTE_KEY_2_HERE
SUMMARIZATION_LLM_PROVIDER=groq_2

# Key 3 → Translation
GROQ_API_KEY_3=gsk_PASTE_KEY_3_HERE
TRANSLATION_LLM_PROVIDER=groq_3

# Key 4 → Q&A
GROQ_API_KEY_4=gsk_PASTE_KEY_4_HERE
QA_LLM_PROVIDER=groq_4

# Key 5 → Agent / Paper Discovery
GROQ_API_KEY_5=gsk_PASTE_KEY_5_HERE
AGENT_LLM_PROVIDER=groq_5

# ── Gemini API Keys (STT) ────────────────────────────────────
GEMINI_API_KEY=PASTE_GEMINI_KEY_1_HERE
GEMINI_API_KEY_2=PASTE_GEMINI_KEY_2_HERE

# ── Other LLM Keys (leave empty if not used) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# ── LLM Settings ─────────────────────────────────────────────
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENT=5
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000

# ── NLP Modes (all set to LLM — no local models on Codespaces)
SUMMARIZATION_MODE=llm
QA_MODE=llm
TRANSLATION_EN_AR_MODE=llm
TRANSLATION_AR_EN_MODE=llm

# ══════════════════════════════════════════════════════════════
# OCR — Mistral Cloud API (no GPU needed)
# ══════════════════════════════════════════════════════════════
OCR_ENGINE=mistral
MISTRAL_API_KEY=PASTE_MISTRAL_KEY_HERE
LIGHTON_API_KEY=
OCR_API_TIMEOUT=60

# ══════════════════════════════════════════════════════════════
# Voice — Gemini STT + Edge TTS (free, CPU-only)
# ══════════════════════════════════════════════════════════════
STT_PROVIDER=gemini
TTS_PROVIDER=edge_tts
ELEVENLABS_API_KEY=
ELEVENLABS_STT_VOICE_AR=
ELEVENLABS_TTS_VOICE_EN=

# ── Rate Limits ───────────────────────────────────────────────
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_SUMMARIZE=10/minute
RATE_LIMIT_TRANSLATE=10/minute
RATE_LIMIT_OCR=5/minute
RATE_LIMIT_STT=20/minute
RATE_LIMIT_TTS=20/minute

# ── Storage ───────────────────────────────────────────────────
UPLOAD_DIR=/app/storage/uploads
AGENT_DOWNLOAD_DIR=/app/storage/agent_downloads

# ── App ───────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-in-production
SEMANTIC_SCHOLAR_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
