# ══════════════════════════════════════════════════════════════
# Paper Flow AI — GitHub Codespaces Deployment
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in your API keys
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=securepassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=research_assistant
DATABASE_URL=postgresql+asyncpg://admin:securepassword@postgres:5432/research_assistant

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ══════════════════════════════════════════════════════════════
# LLM PROVIDERS — 5 Groq API keys distributed across services
# ══════════════════════════════════════════════════════════════

# Default provider (used as fallback)
LLM_PROVIDER=groq

# API Keys — fill in your 5 Groq keys
GROQ_API_KEY=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
GROQ_API_KEY_2=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
GROQ_API_KEY_3=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
GROQ_API_KEY_4=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
GROQ_API_KEY_5=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

# Per-service LLM provider routing
CHAT_LLM_PROVIDER=groq
SUMMARIZATION_LLM_PROVIDER=groq_2
TRANSLATION_LLM_PROVIDER=groq_3
QA_LLM_PROVIDER=groq_4
AGENT_LLM_PROVIDER=groq_5

# ── Gemini API Keys (STT + TTS fallback) ─────────────────────
GEMINI_API_KEY=AIzaSyB4JcYtTY1FcZzkSVVgd59Un0eJ5Dt9KGs
GEMINI_API_KEY_2=AIzaSyAMScKojPlM1WjjcCKMM9XqoaUMbQ6y1CQ



# ── Other LLM Keys (optional) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# ── LLM Settings ──────────────────────────────────────────────
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENT=5
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000

# ── NLP Modes (use LLM for all on Codespaces) ────────────────
SUMMARIZATION_MODE=llm
QA_MODE=llm
TRANSLATION_EN_AR_MODE=llm
TRANSLATION_AR_EN_MODE=llm

# ══════════════════════════════════════════════════════════════
# OCR — Mistral Cloud API (no local GPU needed)
# ══════════════════════════════════════════════════════════════
OCR_ENGINE=mistral
MISTRAL_API_KEY=97ZQlsV45YrDusgZRwjArWGbh3nerFPb
LIGHTON_API_KEY=
OCR_API_TIMEOUT=60

# ══════════════════════════════════════════════════════════════
# VOICE — Gemini STT + Edge TTS (free, no GPU)
# ══════════════════════════════════════════════════════════════
STT_PROVIDER=gemini
TTS_PROVIDER=edge_tts
ELEVENLABS_API_KEY=
ELEVENLABS_STT_VOICE_AR=
ELEVENLABS_TTS_VOICE_EN=

# ── Rate Limits ───────────────────────────────────────────────
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_SUMMARIZE=10/minute
RATE_LIMIT_TRANSLATE=10/minute
RATE_LIMIT_OCR=5/minute
RATE_LIMIT_STT=20/minute
RATE_LIMIT_TTS=20/minute

# ── Storage ───────────────────────────────────────────────────
UPLOAD_DIR=/app/storage/uploads
AGENT_DOWNLOAD_DIR=/app/storage/agent_downloads

# ── App ───────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-in-production
SEMANTIC_SCHOLAR_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
